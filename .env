# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=property_rental

# JWT
JWT_SECRET=MySecureKey123
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=dummy_key
STRIPE_WEBHOOK_SECRET=dummy_webhook
# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=dummy_email@gmail.com
EMAIL_PASS=dummy_app_password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
